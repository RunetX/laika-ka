<?xml version="1.0" encoding="UTF-8"?>
<Form xmlns="http://v8.1c.ru/8.3/xcf/logform" xmlns:app="http://v8.1c.ru/8.2/managed-application/core" xmlns:cfg="http://v8.1c.ru/8.1/data/enterprise/current-config" xmlns:dcscor="http://v8.1c.ru/8.1/data-composition-system/core" xmlns:dcsset="http://v8.1c.ru/8.1/data-composition-system/settings" xmlns:ent="http://v8.1c.ru/8.1/data/enterprise" xmlns:lf="http://v8.1c.ru/8.2/managed-application/logform" xmlns:pal="http://v8.1c.ru/8.1/data/ui/colors/palette" xmlns:style="http://v8.1c.ru/8.1/data/ui/style" xmlns:sys="http://v8.1c.ru/8.1/data/ui/fonts/system" xmlns:v8="http://v8.1c.ru/8.1/data/core" xmlns:v8ui="http://v8.1c.ru/8.1/data/ui" xmlns:web="http://v8.1c.ru/8.1/data/ui/colors/web" xmlns:win="http://v8.1c.ru/8.1/data/ui/colors/windows" xmlns:xr="http://v8.1c.ru/8.3/xcf/readable" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="2.21">
	<Title>
		<v8:item>
			<v8:lang>ru</v8:lang>
			<v8:content>Продлить подписку</v8:content>
		</v8:item>
	</Title>
	<Width>50</Width>
	<WindowOpeningMode>LockOwner</WindowOpeningMode>
	<Group>Vertical</Group>
	<AutoCommandBar name="FormCommandBar" id="-1">
		<Autofill>false</Autofill>
	</AutoCommandBar>
	<Events>
		<Event name="OnOpen">OnOpen</Event>
	</Events>
	<ChildItems>
		<UsualGroup name="GroupLicenseInfo" id="1">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Информация о подписке</v8:content>
				</v8:item>
			</Title>
			<Group>Vertical</Group>
			<Representation>WeakSeparation</Representation>
			<ExtendedTooltip name="GroupLicenseInfoExtendedTooltip" id="2"/>
			<ChildItems>
				<LabelDecoration name="LabelPlan" id="3">
					<Title formatted="false">
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Тариф: —</v8:content>
						</v8:item>
					</Title>
					<ContextMenu name="LabelPlanContextMenu" id="4"/>
					<ExtendedTooltip name="LabelPlanExtendedTooltip" id="5"/>
				</LabelDecoration>
				<LabelDecoration name="LabelExpires" id="6">
					<Title formatted="false">
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Действует до: —</v8:content>
						</v8:item>
					</Title>
					<ContextMenu name="LabelExpiresContextMenu" id="7"/>
					<ExtendedTooltip name="LabelExpiresExtendedTooltip" id="8"/>
				</LabelDecoration>
			</ChildItems>
		</UsualGroup>
		<UsualGroup name="GroupPeriod" id="9">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Период оплаты</v8:content>
				</v8:item>
			</Title>
			<Group>Vertical</Group>
			<Representation>WeakSeparation</Representation>
			<ExtendedTooltip name="GroupPeriodExtendedTooltip" id="10"/>
			<ChildItems>
				<RadioButtonField name="PeriodSelector" id="11">
					<DataPath>Period</DataPath>
					<Title>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Период</v8:content>
						</v8:item>
					</Title>
					<RadioButtonType>Auto</RadioButtonType>
					<ColumnsCount>1</ColumnsCount>
					<ContextMenu name="PeriodSelectorContextMenu" id="12"/>
					<ExtendedTooltip name="PeriodSelectorExtendedTooltip" id="13"/>
				</RadioButtonField>
				<LabelDecoration name="LabelPrice" id="14">
					<Title formatted="false">
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Стоимость: —</v8:content>
						</v8:item>
					</Title>
					<ContextMenu name="LabelPriceContextMenu" id="15"/>
					<ExtendedTooltip name="LabelPriceExtendedTooltip" id="16"/>
				</LabelDecoration>
			</ChildItems>
		</UsualGroup>
		<Button name="ButtonPay" id="17">
			<Type>UsualButton</Type>
			<DefaultButton>true</DefaultButton>
			<CommandName>Form.Command.Pay</CommandName>
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Оплатить через СБП</v8:content>
				</v8:item>
			</Title>
			<ExtendedTooltip name="ButtonPayExtendedTooltip" id="18"/>
		</Button>
		<UsualGroup name="GroupQR" id="19">
			<Visible>false</Visible>
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>QR-код для оплаты</v8:content>
				</v8:item>
			</Title>
			<Group>Vertical</Group>
			<Representation>WeakSeparation</Representation>
			<ExtendedTooltip name="GroupQRExtendedTooltip" id="20"/>
			<ChildItems>
				<LabelDecoration name="LabelScanQR" id="21">
					<Title formatted="false">
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Отсканируйте QR-код в приложении банка:</v8:content>
						</v8:item>
					</Title>
					<ContextMenu name="LabelScanQRContextMenu" id="22"/>
					<ExtendedTooltip name="LabelScanQRExtendedTooltip" id="23"/>
				</LabelDecoration>
				<PictureField name="PictureQR" id="24">
					<DataPath>QRPicture</DataPath>
					<Width>20</Width>
					<Height>10</Height>
					<PictureSize>Proportionally</PictureSize>
					<ContextMenu name="PictureQRContextMenu" id="25"/>
					<ExtendedTooltip name="PictureQRExtendedTooltip" id="26"/>
				</PictureField>
				<LabelDecoration name="LabelStatus" id="27">
					<Title formatted="false">
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Статус: ожидание оплаты...</v8:content>
						</v8:item>
					</Title>
					<ContextMenu name="LabelStatusContextMenu" id="28"/>
					<ExtendedTooltip name="LabelStatusExtendedTooltip" id="29"/>
				</LabelDecoration>
			</ChildItems>
		</UsualGroup>
	</ChildItems>
	<Attributes>
		<Attribute name="Object" id="1">
			<Type>
				<v8:Type>cfg:DataProcessorObject.like_billing</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
		</Attribute>
		<Attribute name="Period" id="2">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Период</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>xs:string</v8:Type>
				<v8:StringQualifiers>
					<v8:Length>10</v8:Length>
					<v8:AllowedLength>Variable</v8:AllowedLength>
				</v8:StringQualifiers>
			</Type>
		</Attribute>
		<Attribute name="PaymentId" id="3">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Payment ID</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>xs:string</v8:Type>
				<v8:StringQualifiers>
					<v8:Length>50</v8:Length>
					<v8:AllowedLength>Variable</v8:AllowedLength>
				</v8:StringQualifiers>
			</Type>
		</Attribute>
		<Attribute name="QRPicture" id="4">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>QR</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>xs:string</v8:Type>
				<v8:StringQualifiers>
					<v8:Length>0</v8:Length>
					<v8:AllowedLength>Variable</v8:AllowedLength>
				</v8:StringQualifiers>
			</Type>
		</Attribute>
	</Attributes>
	<Commands>
		<Command name="Pay" id="1">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Оплатить через СБП</v8:content>
				</v8:item>
			</Title>
			<ToolTip>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Создать платёж и получить QR-код</v8:content>
				</v8:item>
			</ToolTip>
			<Action>Pay</Action>
		</Command>
	</Commands>
</Form>