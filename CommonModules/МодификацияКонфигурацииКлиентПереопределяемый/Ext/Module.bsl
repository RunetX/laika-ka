&После("ВыполнитьПереопределяемуюКоманду")
Процедура like_ВыполнитьПереопределяемуюКоманду(Форма, Команда, ДополнительныеПараметры)

	Если Команда.Имя = "like_Send2IIKO" Тогда
		like_ОтправитьВIIKO(Форма);
	КонецЕсли;

КонецПроцедуры

Процедура like_ОтправитьВIIKO(Форма)

	СписокДокументов = Форма.Элементы.Найти("СписокДокументыПоступления");
	Если СписокДокументов = Неопределено Тогда
		Возврат;
	КонецЕсли;

	МассивНакладных = Новый Массив;
	Для Каждого ВыделеннаяСтрока Из СписокДокументов.ВыделенныеСтроки Цикл
		МассивНакладных.Добавить(ВыделеннаяСтрока);
	КонецЦикла;

	Если МассивНакладных.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	КоличествоНесопоставленных = like_DocumentAtServer.GetUnmatchedCount(МассивНакладных);

	Если КоличествоНесопоставленных > 0 Тогда
		АдресСписка = ПоместитьВоВременноеХранилище(МассивНакладных, Форма.УникальныйИдентификатор);
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("documentsListRef", АдресСписка);
		ПараметрыФормы.Вставить("sendAfterMatch", Истина);
		ОткрытьФорму("ОбщаяФорма.like_unmatchedObjectsForm", ПараметрыФормы);
	Иначе
		like_InvoicesAtServer.SendInvoices2IIKO(МассивНакладных);
	КонецЕсли;

КонецПроцедуры
