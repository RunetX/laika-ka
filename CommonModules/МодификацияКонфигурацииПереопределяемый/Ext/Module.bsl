&После("ПриСозданииНаСервере")
Процедура like_ПриСозданииНаСервере(Форма, Отказ, СтандартнаяОбработка)

	Если Форма.ИмяФормы = "Документ.ПриобретениеТоваровУслуг.Форма.ФормаСписка" Тогда
		like_ДобавитьКомандуОтправкиВIIKO(Форма);
		like_ДобавитьФормуЗагрузкиНакладных(Форма);
	КонецЕсли;

КонецПроцедуры

#Область КнопкаОтправкиВIIKO

Процедура like_ДобавитьКомандуОтправкиВIIKO(Форма)

	Команда = Форма.Команды.Добавить("like_Send2IIKO");
	Команда.Заголовок  = НСтр("ru = 'Отправить в IIKO'; en = 'Send to IIKO'");
	Команда.Действие   = "Подключаемый_ВыполнитьПереопределяемуюКоманду";
	Команда.Картинка   = БиблиотекаКартинок.Отправить;
	Команда.Отображение = ОтображениеКнопки.КартинкаИТекст;

	КоманднаяПанель = Форма.Элементы.Найти("СписокДокументыПоступленияКоманднаяПанель");
	Если КоманднаяПанель = Неопределено Тогда
		КоманднаяПанель = Форма.Элементы.Найти("ФормаКоманднаяПанель");
	КонецЕсли;

	Если КоманднаяПанель <> Неопределено Тогда
		Кнопка = Форма.Элементы.Добавить("like_Send2IIKOButton", Тип("КнопкаФормы"), КоманднаяПанель);
		Кнопка.ИмяКоманды = "like_Send2IIKO";
		Кнопка.Вид = ВидКнопкиФормы.КнопкаКоманднойПанели;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ФормаЗагрузкиНакладных

Процедура like_ДобавитьФормуЗагрузкиНакладных(Форма)

	like_ДобавитьРеквизитыНакладных(Форма);
	like_ДобавитьКомандыНакладных(Форма);
	like_ДобавитьЭлементыНакладных(Форма);

	Форма["like_loadIncomingInvoices"] = Истина;
	Форма["like_loadOutgoingInvoices"] = Истина;

КонецПроцедуры

Процедура like_ДобавитьРеквизитыНакладных(Форма)

	НР = Новый Массив; // НовыеРеквизиты

	// Скалярные: РеквизитФормы(Имя, Тип, Путь, Заголовок)
	НР.Добавить(Новый РеквизитФормы("like_period",
		Новый ОписаниеТипов("СтандартныйПериод"),, НСтр("ru = 'Период'")));
	НР.Добавить(Новый РеквизитФормы("like_loadIncomingInvoices",
		Новый ОписаниеТипов("Булево"),, НСтр("ru = 'Приходные накладные'")));
	НР.Добавить(Новый РеквизитФормы("like_loadOutgoingInvoices",
		Новый ОписаниеТипов("Булево"),, НСтр("ru = 'Расходные накладные'")));
	НР.Добавить(Новый РеквизитФормы("like_sumSum",
		Новый ОписаниеТипов("Строка")));
	НР.Добавить(Новый РеквизитФормы("like_sumSumWithoutNds",
		Новый ОписаниеТипов("Строка")));
	НР.Добавить(Новый РеквизитФормы("like_count",
		Новый ОписаниеТипов("Строка")));

	// Таблица накладных
	НР.Добавить(Новый РеквизитФормы("like_invoicesList",
		Новый ОписаниеТипов("ТаблицаЗначений"),, НСтр("ru = 'Список накладных'")));

	// Колонки таблицы: РеквизитФормы(Имя, Тип, Путь, Заголовок)
	ОТДата      = Новый ОписаниеТипов("Дата",,, Новый КвалификаторыДаты(ЧастиДаты.Дата));
	ОТСтр36     = Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(36));
	ОТСтр20     = Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(20));
	ОТСтр100    = Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(100));
	ОТЧисло10_2 = Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(10, 2));
	ОТЧислоТип  = Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(1, 0, ДопустимыйЗнак.Неотрицательный));
	ОТБулево    = Новый ОписаниеТипов("Булево");

	П = "like_invoicesList"; // Путь — имя родительского реквизита-таблицы
	НР.Добавить(Новый РеквизитФормы("date",                  ОТДата,      П, НСтр("ru = 'Дата'")));
	НР.Добавить(Новый РеквизитФормы("counteragent",          ОТСтр36,     П, НСтр("ru = 'Контрагент UUID'")));
	НР.Добавить(Новый РеквизитФормы("number",                ОТСтр20,     П, НСтр("ru = '№ документа'")));
	НР.Добавить(Новый РеквизитФормы("documentSummary",       ОТСтр100,    П, НСтр("ru = 'Доп. информация'")));
	НР.Добавить(Новый РеквизитФормы("sum",                   ОТЧисло10_2, П, НСтр("ru = 'Сумма'")));
	НР.Добавить(Новый РеквизитФормы("processed",             ОТБулево,    П, НСтр("ru = 'Проведен'")));
	НР.Добавить(Новый РеквизитФормы("conception",            ОТСтр36,     П, НСтр("ru = 'Концепция UUID'")));
	НР.Добавить(Новый РеквизитФормы("comment",               ОТСтр100,    П, НСтр("ru = 'Комментарий'")));
	НР.Добавить(Новый РеквизитФормы("assignedStoreUUID",     ОТСтр36,     П, НСтр("ru = 'Склад UUID'")));
	НР.Добавить(Новый РеквизитФормы("sumWithoutNds",         ОТЧисло10_2, П, НСтр("ru = 'Сумма без НДС'")));
	НР.Добавить(Новый РеквизитФормы("invoiceIncomingNumber", ОТСтр100,    П, НСтр("ru = 'Входящий номер'")));
	НР.Добавить(Новый РеквизитФормы("type",                  ОТЧислоТип,  П, "Type"));
	НР.Добавить(Новый РеквизитФормы("documentID",            ОТСтр36,     П, "DocumentID"));
	НР.Добавить(Новый РеквизитФормы("store",                 ОТСтр100,    П, НСтр("ru = 'Склад'")));

	МассивТипов = Новый Массив;
	МассивТипов.Добавить(Тип("СправочникСсылка.like_conceptions"));
	ОТКонцепция = Новый ОписаниеТипов(МассивТипов);
	НР.Добавить(Новый РеквизитФормы("conceptionRef", ОТКонцепция, П, НСтр("ru = 'Концепция'")));

	МассивТипов = Новый Массив;
	МассивТипов.Добавить(Тип("СправочникСсылка.like_users"));
	ОТПоставщик = Новый ОписаниеТипов(МассивТипов);
	НР.Добавить(Новый РеквизитФормы("counteragentRef", ОТПоставщик, П, НСтр("ru = 'Поставщик/покупатель'")));

	Форма.ИзменитьРеквизиты(НР);

КонецПроцедуры

Процедура like_ДобавитьКомандыНакладных(Форма)

	Команда = Форма.Команды.Добавить("like_UpdateInvoicesList");
	Команда.Заголовок = НСтр("ru = 'Обновить'; en = 'Update'");
	Команда.Действие  = "like_UpdateInvoicesList";

КонецПроцедуры

Процедура like_ДобавитьЭлементыНакладных(Форма)

	// Группа "Накладные IIKO"
	Группа = Форма.Элементы.Добавить("like_InvoicesGroup", Тип("ГруппаФормы"), Форма);
	Группа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	Группа.Отображение = ОтображениеОбычнойГруппы.СлабоеВыделение;
	Группа.Заголовок   = НСтр("ru = 'Накладные IIKO'");

	// Строка фильтров
	ГруппаФильтров = Форма.Элементы.Добавить("like_InvoicesFilter", Тип("ГруппаФормы"), Группа);
	ГруппаФильтров.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаФильтров.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяЕслиВозможно;
	ГруппаФильтров.Отображение = ОтображениеОбычнойГруппы.Нет;
	ГруппаФильтров.ОтображатьЗаголовок = Ложь;

	// Чекбоксы
	Флажок1 = Форма.Элементы.Добавить("like_loadIncomingInvoices", Тип("ПолеФормы"), ГруппаФильтров);
	Флажок1.Вид = ВидПоляФормы.ПолеФлажка;
	Флажок1.ПутьКДанным = "like_loadIncomingInvoices";

	Флажок2 = Форма.Элементы.Добавить("like_loadOutgoingInvoices", Тип("ПолеФормы"), ГруппаФильтров);
	Флажок2.Вид = ВидПоляФормы.ПолеФлажка;
	Флажок2.ПутьКДанным = "like_loadOutgoingInvoices";

	// Период
	ПолеПериода = Форма.Элементы.Добавить("like_period", Тип("ПолеФормы"), ГруппаФильтров);
	ПолеПериода.Вид = ВидПоляФормы.ПолеВвода;
	ПолеПериода.ПутьКДанным = "like_period";

	// Кнопка "Обновить"
	КнопкаОбновить = Форма.Элементы.Добавить("like_UpdateInvoicesListBtn", Тип("КнопкаФормы"), ГруппаФильтров);
	КнопкаОбновить.ИмяКоманды = "like_UpdateInvoicesList";
	КнопкаОбновить.Вид = ВидКнопкиФормы.ОбычнаяКнопка;

	// Таблица накладных
	Таблица = Форма.Элементы.Добавить("like_invoicesList", Тип("ТаблицаФормы"), Группа);
	Таблица.ПутьКДанным = "like_invoicesList";
	Таблица.Отображение = ОтображениеТаблицы.Список;
	Таблица.РежимВыделенияСтроки = РежимВыделенияСтрокиТаблицы.Ячейка;
	Таблица.Подвал = Истина;
	Таблица.УстановитьДействие("Выбор", "like_InvoicesListSelection");

	// Колонки таблицы
	like_ДобавитьКолонку(Форма, Таблица, "date",                  НСтр("ru = 'Дата'"));
	like_ДобавитьКолонку(Форма, Таблица, "counteragentRef",       НСтр("ru = 'Поставщик/покупатель'"));
	Кол = like_ДобавитьКолонку(Форма, Таблица, "number",          НСтр("ru = '№ документа'"));
	Кол.ПутьКДаннымПодвала = "like_count";
	like_ДобавитьКолонку(Форма, Таблица, "documentSummary",       НСтр("ru = 'Доп. информация'"));
	Кол = like_ДобавитьКолонку(Форма, Таблица, "sum",             НСтр("ru = 'Сумма'"));
	Кол.ПутьКДаннымПодвала = "like_sumSum";
	like_ДобавитьКолонку(Форма, Таблица, "processed",             НСтр("ru = 'Проведен'"));
	like_ДобавитьКолонку(Форма, Таблица, "conceptionRef",         НСтр("ru = 'Концепция'"));
	like_ДобавитьКолонку(Форма, Таблица, "comment",               НСтр("ru = 'Комментарий'"));
	like_ДобавитьКолонку(Форма, Таблица, "store",                 НСтр("ru = 'Склад'"));
	Кол = like_ДобавитьКолонку(Форма, Таблица, "sumWithoutNds",   НСтр("ru = 'Сумма без НДС'"));
	Кол.ПутьКДаннымПодвала = "like_sumSumWithoutNds";
	like_ДобавитьКолонку(Форма, Таблица, "invoiceIncomingNumber",  НСтр("ru = 'Входящий номер'"));

КонецПроцедуры

Функция like_ДобавитьКолонку(Форма, Таблица, ИмяКолонки, Заголовок)

	Колонка = Форма.Элементы.Добавить("like_il_" + ИмяКолонки, Тип("ПолеФормы"), Таблица);
	Колонка.Вид = ВидПоляФормы.ПолеВвода;
	Колонка.ПутьКДанным = "like_invoicesList." + ИмяКолонки;
	Колонка.Заголовок = Заголовок;
	Колонка.ТолькоПросмотр = Истина;
	Возврат Колонка;

КонецФункции

#КонецОбласти
